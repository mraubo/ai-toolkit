{
  "claude": {
    "name": "Claude Code",
    "detect": ["CLAUDE.md", ".claude/"],
    "targets": {
      "project": {
        "skills_dir": ".claude/skills",
        "rules_file": "CLAUDE.md"
      },
      "global": {
        "skills_dir": "~/.claude/skills",
        "rules_file": "~/.claude/CLAUDE.md"
      }
    }
  },
  "cursor": {
    "name": "Cursor",
    "detect": [".cursor/"],
    "targets": {
      "project": {
        "skills_dir": ".cursor/skills",
        "rules_file": "AGENTS.md"
      },
      "global": {
        "skills_dir": "~/.cursor/skills",
        "rules_file": "~/AGENTS.md"
      }
    }
  },
  "codex": {
    "name": "Codex CLI",
    "detect": ["AGENTS.md", ".codex/", ".agents/"],
    "targets": {
      "project": {
        "skills_dir": ".agents/skills",
        "rules_file": "AGENTS.md"
      },
      "global": {
        "skills_dir": "~/.agents/skills",
        "rules_file": "~/AGENTS.md"
      }
    }
  }
}
